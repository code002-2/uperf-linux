#!/bin/sh
set -e

case "$1" in
    configure)
        # Create runtime directory
        mkdir -p /run/uperf-linux
        chmod 755 /run/uperf-linux

        # Enable and start the daemon if not already running
        if systemctl is-active --quiet uperf-linux.service 2>/dev/null; then
            systemctl reload uperf-linux.service 2>/dev/null || true
        else
            systemctl enable uperf-linux.service 2>/dev/null || true
            systemctl start uperf-linux.service 2>/dev/null || true
        fi

        # Set up permissions for sysfs access
        # The daemon runs as root via systemd, so this is handled

        echo "uperf-linux GUI installed successfully."
        echo "Start the daemon: sudo systemctl start uperf-linux"
        echo "Launch GUI: uperf-gui"
        ;;

    abort-upgrade|abort-remove|abort-deconfigure)
        ;;

    *)
        echo "postinst called with unknown argument '$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
